      ],
      "relatedTools": [
        "jm-rundown",
        "jm-switcher",
        "jm-caption",
        "jm-timer",
        "jm-prompter"
      ],
      "prerequisites": [
        "Stabile Upload-Leitung (mind. 10 Mbit/s)",
        "Backup-Internet (Mobile-Hotspot)",
        "Separate Mischpulte für Saal und Stream"
      ],
      "equipmentOwner": "jm",
      "crewRoles": [
        "Eventleitung",
