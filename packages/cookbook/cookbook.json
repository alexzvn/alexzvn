      "prerequisites": [
        "Strom 230 V / 10 A, einzeln abgesichert",
        "DSL-/Upload-Zugang vom Kunden",
        "Raumzugang am Aufbau- und am Showtag"
      ],
      "equipmentOwner": "jm",
      "crewRoles": [
        "Regie",
        "Media Operator Video (TriCaster)",
        "Media Operator Audio"
