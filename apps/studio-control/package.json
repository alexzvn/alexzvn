{
  "name": "@jm/studio-control",
  "version": "0.5.0",
  "private": true,
  "description": "Jakobs Medien Studio Control — central LAN tool for video, audio, and lighting",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "start:codespace": "unset ELECTRON_RUN_AS_NODE && xvfb-run -a node_modules/.bin/electron out/main/index.cjs",
    "rebuild:native": "electron-rebuild --only better-sqlite3",
    "postinstall": "electron-rebuild --only better-sqlite3 || true",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "mock:tricaster": "tsx tools/mock-tricaster.ts",
    "mock:ptz": "tsx tools/mock-ptz.ts",
    "mock:artnet": "tsx tools/mock-artnet.ts",
    "mock:audio": "tsx tools/mock-audio.ts",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.1.1",
    "@jm/app-runtime": "*",
    "@jm/ui": "*",
    "better-sqlite3": "^11.3.0",
    "bonjour-service": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "24.13.3",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
