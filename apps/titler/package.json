{
  "name": "@jm/titler",
  "version": "0.3.0",
  "private": true,
  "description": "JM Titler — Live-Bauchbinden/CG als transparente NDI-Quelle für TriCaster/vMix/OBS",
  "main": "out/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "prepackage": "node tools/bundle-ndi.mjs",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "dist:win": "electron-vite build && npm run prepackage && electron-builder --win"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.1.1",
    "@jm/app-runtime": "*",
    "@jm/ndi": "*",
    "@jm/suite-control-protocol": "*",
    "@jm/ui": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "24.13.3",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
